{
  "name": "xiyu-bid-poc",
  "version": "1.0.0",
  "description": "西域数智化投标管理平台POC",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "check:front-data-boundaries": "node scripts/check-front-data-boundaries.mjs",
    "check:doc-governance": "node scripts/check-doc-governance.mjs",
    "build": "npm run check:front-data-boundaries && npm run check:doc-governance && vite build",
    "preview": "vite preview",
    "test:e2e:commercial": "npx playwright test --config playwright.config.js",
    "check-docs": "bash scripts/check-doc-consistency.sh"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "axios": "^1.6.0",
    "echarts": "^5.4.0",
    "element-plus": "^2.5.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^5.0.0",
    "sass": "^1.70.0",
    "vite": "^5.0.0"
  }
}
